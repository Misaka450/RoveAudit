# ==========================================
# 运营商数据门户平台 - 环境配置
# 复制为 .env 后填入实际值
# cp .env.example .env
# ==========================================

# 服务端口
APP_PORT=3000

# JWT 配置
# openssl rand -base64 32
JWT_SECRET=your-j...n
# PostgreSQL 系统数据库（用户、角色、权限、菜单等）
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=data_portal
PG_PASSWORD=your-p...n
# Doris 业务数据库（清单查询、数据分析）
# Doris 兼容 MySQL 协议，使用 mysql2 驱动
DORIS_HOST=10.10.0.3
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=your-d...
DORIS_DATABASE=your-d...
DORIS_POOL_SIZE=10

